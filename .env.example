APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/zoom_agentic_ai

TRANSCRIPT_STORAGE_DIR=transcripts
LOG_DIR=logs

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=
ZOOM_TOKEN_URL=https://zoom.us/oauth/token
ZOOM_API_BASE_URL=https://api.zoom.us/v2
ZOOM_WEBHOOK_VERIFY_SIGNATURE=true
ZOOM_WEBHOOK_TOLERANCE_SECONDS=300
ZOOM_OAUTH_TIMEOUT_SECONDS=10
ZOOM_OAUTH_RETRY_ATTEMPTS=3
ZOOM_OAUTH_RETRY_BACKOFF_SECONDS=1.0

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen3:8b
OLLAMA_FALLBACK_MODEL=llama3:8b
OLLAMA_CONNECT_TIMEOUT_SECONDS=10
OLLAMA_READ_TIMEOUT_SECONDS=300
OLLAMA_RETRY_ATTEMPTS=3
OLLAMA_RETRY_BACKOFF_SECONDS=2.0

QUESTION_MIN_COUNT=10
QUESTION_MAX_COUNT=20
MAX_CHUNK_TOKENS=1800
